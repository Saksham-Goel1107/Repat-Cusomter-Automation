# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your values.
#
# NEVER commit .env or service.json to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Google Sheets spreadsheet ID for raw sale data (source).
# Find it in the URL: https://docs.google.com/spreadsheets/d/<ID>/edit
INPUT_SPREADSHEET_ID=your_input_spreadsheet_id_here

# Google Sheets spreadsheet ID + tab name for the stock/inventory report.
# This is the sheet that contains the purchasePrice column.
# If your stock report is a different tab in the SAME spreadsheet as the sales
# report, you only need to set STOCK_SHEET_NAME—leave STOCK_SPREADSHEET_ID blank.
# If it is a completely separate spreadsheet, set STOCK_SPREADSHEET_ID as well.
STOCK_SPREADSHEET_ID=                    # leave blank = same spreadsheet as INPUT
STOCK_SHEET_NAME=Stock                   # exact tab name in the stock spreadsheet

# Google Sheets spreadsheet ID where results will be written (can be the same
# spreadsheet or a different one — the service account must have Editor access).
OUTPUT_SPREADSHEET_ID=your_output_spreadsheet_id_here


# ── OPTIONAL — override defaults as needed ───────────────────────────────────

# Name of the tab / worksheet in the input spreadsheet.
INPUT_SHEET_NAME=Sheet1

# ── COLUMN NAME MAPPING ────────────────────────────────────────────────────────────────
# Change these if your sheet headers use different names.

# In the SALES report:
COL_SALES_CODE=code          # column that identifies the product/item
COL_SALES_QTY=quantity       # column for the quantity sold per line item

# In the STOCK report:
COL_STOCK_CODE=code          # column that identifies the product/item (joined to sales)
COL_STOCK_PURCHASE_PRICE=purchasePrice   # column for the unit purchase/cost price

# Path to the service account JSON key inside the container.
# Default matches the Docker volume mount in docker-compose.yml.
GOOGLE_CREDENTIALS_PATH=/app/credentials/service.json

# Cashier value used to filter the billed_by column.
CASHIER_FILTER=sw-noida-cashier

# Timezone for date normalisation.
TIMEZONE=Asia/Kolkata

# Cron schedule (standard 5-field cron syntax, evaluated in UTC).
# Default: 01:00 UTC daily = 06:30 IST
CRON_SCHEDULE=0 1 * * *

# Set to "true" to read + analyse without writing anything back to Sheets.
# Useful for smoke-testing a new deployment.
DRY_RUN=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json     # "json" (structured, for log aggregators) | "text" (human readable)

# Google Sheets retry behaviour
SHEETS_MAX_RETRIES=5
SHEETS_RETRY_DELAY_S=2.0

# ── Output sheet tab names (change if you want different names) ──────────────
OUT_TAB_PERIOD_MATRIX=Customer_Period_Matrix
OUT_TAB_REPEAT_CUSTOMERS=Repeat_Customers
OUT_TAB_UNKNOWN_CUSTOMERS=Unknown_Customers
OUT_TAB_CUSTOMER_SUMMARY=Customer_Summary
OUT_TAB_SEGMENT_METRICS=Segment_Metrics
OUT_TAB_ONCE_VS_REPEAT=Once_vs_Repeat
OUT_TAB_REPEAT_BILL_METRICS=Repeat_Bill_Metrics
OUT_TAB_RECOVERY_FULL=Recovery_Full_Range
OUT_TAB_RECOVERY_JAN1=Recovery_Till_Jan1
OUT_TAB_RECOVERY_JAN15=Recovery_Till_Jan15
OUT_TAB_RECOVERY_FEB1=Recovery_Till_Feb1
OUT_TAB_RUN_LOG=Run_Log
